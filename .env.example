# docker-compose environment variables
# Copy to .env and fill in real values before running docker-compose up
# docker-compose automatically reads .env from the project root directory.

# Generate 48 bytes (384 bits) of entropy with: openssl rand -base64 48
# The output will be ~64 characters — that's the AUTH_SECRET value to use.
AUTH_SECRET=replace-with-output-of--openssl-rand-base64-48
