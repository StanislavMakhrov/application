# GrünBilanz — Environment Variables
# Copy this file to .env.local and fill in your Supabase project credentials.
# The Supabase project MUST be hosted in the EU region (Frankfurt, eu-central-1)
# for DSGVO / data residency compliance.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
