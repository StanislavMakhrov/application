# GrünBilanz — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# Supabase project URL (found in Supabase project settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key (found in Supabase project settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma connection string — use the "connection pooling" URL from Supabase
DATABASE_URL=

# Prisma direct connection — use the direct (non-pooled) URL from Supabase
# Required for Prisma migrations
DIRECT_URL=
